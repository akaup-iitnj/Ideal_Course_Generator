# Copy to .env in this folder (UTF-8, no BOM).
# HeyGen dashboard API key
HEYGEN_API_KEY=your-heygen-api-key

# Optional: pin avatar and voice (otherwise first match from API is used)
# HEYGEN_AVATAR_ID=
# HEYGEN_VOICE_ID=

# Optional: background image fit for scenes: cover | contain | none | crop
# HEYGEN_BG_FIT=cover

# Optional: avatar position (defaults in run_stage3.py)
# HEYGEN_OFFSET_X=0
# HEYGEN_OFFSET_Y=0
# HEYGEN_AVATAR_SCALE=1.0

# Long jobs: raise if HeyGen takes longer than default (minutes)
# HEYGEN_POLL_TIMEOUT_MINUTES=120

# Debug: set to 1 / true / yes to log full status payloads
# HEYGEN_LOG_STATUS_DEBUG=
